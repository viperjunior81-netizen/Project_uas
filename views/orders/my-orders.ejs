<h1>Pesanan Saya</h1>

<% if (orders.length === 0) { %>
  <div class="empty-state">
    <p>Kamu belum memiliki pesanan.</p>
    <a href="/products" class="btn btn-primary">Mulai Belanja</a>
  </div>
<% } else { %>
  <div class="grid" style="grid-template-columns:1fr;gap:14px;">
    <% orders.forEach(o => { %>
      <a href="/orders/<%= o.id %>" class="card card-pad" style="display:flex;justify-content:space-between;align-items:center;">
        <div>
          <strong>Pesanan #<%= o.id %></strong>
          <div class="muted" style="font-size:0.82rem;"><%= new Date(o.createdAt).toLocaleString('id-ID') %> · <%= o.items.length %> item</div>
        </div>
        <div style="text-align:right;">
          <div class="badge badge-<%= o.status %>"><%= o.status %></div>
          <div style="font-weight:700;margin-top:4px;">Rp <%= Number(o.totalAmount).toLocaleString('id-ID') %></div>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>
