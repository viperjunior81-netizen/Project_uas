<h1><%= product ? 'Edit Produk' : 'Tambah Produk' %></h1>

<div class="card card-pad" style="max-width:640px;">
  <form action="<%= product ? `/seller/products/${product.id}` : '/seller/products' %>" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="name">Nama Produk</label>
      <input type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required>
    </div>
    <div class="form-group">
      <label for="description">Deskripsi</label>
      <textarea id="description" name="description" rows="4" required><%= product ? product.description : '' %></textarea>
    </div>
    <div class="form-group">
      <label for="price">Harga (Rp)</label>
      <input type="number" id="price" name="price" min="0" step="1" value="<%= product ? product.price : '' %>" required>
    </div>
    <div class="form-group">
      <label for="stock">Stok</label>
      <input type="number" id="stock" name="stock" min="0" step="1" value="<%= product ? product.stock : 0 %>" required>
    </div>
    <div class="form-group">
      <label for="categoryId">Kategori</label>
      <select id="categoryId" name="categoryId" required>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= product && product.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="images">Gambar Produk (maks 5)</label>
      <input type="file" id="images" name="images" multiple accept="image/png,image/jpeg,image/webp">
      <div class="form-hint">Kosongkan jika tidak ingin mengganti gambar.</div>
    </div>
    <% if (product) { %>
      <div class="form-group">
        <label><input type="checkbox" name="isActive" <%= product.isActive ? 'checked' : '' %>> Tampilkan produk ini ke pembeli</label>
      </div>
    <% } %>
    <button type="submit" class="btn btn-primary btn-block"><%= product ? 'Simpan Perubahan' : 'Tambah Produk' %></button>
  </form>
</div>
