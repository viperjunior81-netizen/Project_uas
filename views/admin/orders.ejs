<h1>Kelola Semua Pesanan</h1>

<table class="data-table" style="margin-top:16px;">
  <thead><tr><th>Order</th><th>Pembeli</th><th>Total</th><th>Status</th><th>Tanggal</th><th></th></tr></thead>
  <tbody>
    <% orders.forEach(o => { %>
      <tr>
        <td>#<%= o.id %></td>
        <td><%= o.buyer.name %> (<%= o.buyer.email %>)</td>
        <td>Rp <%= Number(o.totalAmount).toLocaleString('id-ID') %></td>
        <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
        <td><%= new Date(o.createdAt).toLocaleDateString('id-ID') %></td>
        <td><a href="/orders/<%= o.id %>" class="btn btn-outline btn-sm">Detail</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
