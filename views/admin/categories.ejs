<h1>Kelola Kategori</h1>

<div class="card card-pad" style="max-width:480px;margin-bottom:24px;">
  <form action="/admin/categories" method="POST">
    <div class="form-group">
      <label for="name">Nama Kategori</label>
      <input type="text" id="name" name="name" required>
    </div>
    <div class="form-group">
      <label for="description">Deskripsi</label>
      <textarea id="description" name="description" rows="2"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Tambah Kategori</button>
  </form>
</div>

<table class="data-table">
  <thead><tr><th>Nama</th><th>Slug</th><th>Deskripsi</th><th></th></tr></thead>
  <tbody>
    <% categories.forEach(c => { %>
      <tr>
        <td><%= c.name %></td>
        <td><%= c.slug %></td>
        <td class="muted"><%= c.description %></td>
        <td>
          <form action="/admin/categories/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Hapus kategori ini?');">
            <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
