<div style="display:grid; grid-template-columns: 1fr 1fr; gap:36px; align-items:start;" class="product-detail-grid">
  <div class="card" style="overflow:hidden;">
    <div class="thumb" style="aspect-ratio:1/1;">
      <% if (product.images && product.images.length) { %>
        <img src="<%= product.images[0] %>" alt="<%= product.name %>" style="width:100%;height:100%;object-fit:cover;">
      <% } else { %>
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:4rem;opacity:.25;">📦</div>
      <% } %>
    </div>
  </div>

  <div>
    <span class="cat"><%= product.category ? product.category.name : 'Umum' %></span>
    <h1 style="margin:6px 0 10px;"><%= product.name %></h1>
    <div class="rating" style="margin-bottom:14px;">
      <% if (product.ratingCount > 0) { %>
        <span class="star">★</span> <%= product.ratingAvg %> (<%= product.ratingCount %> ulasan)
      <% } else { %>
        <span class="muted">Belum ada ulasan</span>
      <% } %>
    </div>
    <div class="price-tag" style="font-size:1.4rem;margin-bottom:18px;">Rp <%= Number(product.price).toLocaleString('id-ID') %></div>

    <p class="muted"><%= product.description %></p>
    <p><strong>Stok:</strong> <%= product.stock %> unit</p>

    <div class="card card-pad" style="margin:18px 0; display:flex; align-items:center; gap:12px;">
      <img src="<%= product.seller.avatar %>" class="avatar" alt="">
      <div>
        <div style="font-weight:700;"><%= product.seller.storeName || product.seller.name %></div>
        <div class="muted" style="font-size:0.82rem;">Penjual</div>
      </div>
      <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.id !== product.seller.id) { %>
        <a href="/chat/<%= product.seller.id %>?productId=<%= product.id %>" class="btn btn-outline btn-sm" style="margin-left:auto;">💬 Chat Penjual</a>
      <% } %>
    </div>

    <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'buyer') { %>
      <div style="display:flex; gap:10px;">
        <form action="/cart/add" method="POST" style="flex:1;display:flex;gap:8px;">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>" style="width:80px;">
          <button type="submit" class="btn btn-primary" <%= product.stock === 0 ? 'disabled' : '' %>>🛒 Tambah ke Keranjang</button>
        </form>
        <form action="/wishlist/toggle" method="POST">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <button type="submit" class="btn btn-outline">♥ Wishlist</button>
        </form>
      </div>
      <% if (product.stock === 0) { %><p class="form-error">Stok habis.</p><% } %>
    <% } else if (typeof currentUser === 'undefined' || !currentUser) { %>
      <a href="/auth/login" class="btn btn-primary btn-block">Masuk untuk membeli</a>
    <% } %>
  </div>
</div>

<div class="section-title" style="margin-top:40px;">
  <h2 style="margin:0;">Ulasan Pembeli</h2>
</div>

<% if (product.reviews && product.reviews.length) { %>
  <div class="grid" style="grid-template-columns: 1fr; gap:12px;">
    <% product.reviews.forEach(r => { %>
      <div class="card card-pad">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
          <img src="<%= r.buyer.avatar %>" class="avatar" alt="">
          <strong><%= r.buyer.name %></strong>
          <span class="star"><%= '★'.repeat(r.rating) %><span style="opacity:.25;"><%= '★'.repeat(5 - r.rating) %></span></span>
        </div>
        <p class="muted" style="margin:0;"><%= r.comment %></p>

        <% if (r.sellerReply) { %>
          <div class="card card-pad" style="background:#f4f7f5;margin-top:10px;">
            <strong>💬 Balasan Penjual:</strong>
            <p class="muted" style="margin:4px 0 0;"><%= r.sellerReply %></p>
          </div>
        <% } else if (typeof currentUser !== 'undefined' && currentUser && currentUser.id === product.seller.id) { %>
          <form action="/reviews/<%= r.id %>/reply" method="POST" style="margin-top:10px;display:flex;gap:8px;">
            <input type="text" name="comment" placeholder="Balas ulasan ini..." style="flex:1;" required>
            <button type="submit" class="btn btn-outline btn-sm">Kirim Balasan</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <p class="muted">Belum ada ulasan untuk produk ini.</p>
<% } %>

<% if (related.length) { %>
  <div class="section-title" style="margin-top:40px;">
    <h2 style="margin:0;">Produk Serupa</h2>
  </div>
  <div class="grid grid-products">
    <% related.forEach(p => { %>
      <%- include('../partials/product-card', { p }) %>
    <% }) %>
  </div>
<% } %>

<style>
  @media (max-width: 760px) { .product-detail-grid { grid-template-columns: 1fr !important; } }
</style>