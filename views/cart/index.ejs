<h1>Keranjang Belanja</h1>

<% if (items.length === 0) { %>
  <div class="empty-state">
    <p>Keranjangmu masih kosong.</p>
    <a href="/products" class="btn btn-primary">Mulai Belanja</a>
  </div>
<% } else { %>
  <div class="grid" style="grid-template-columns:1fr;gap:14px;">
    <% items.forEach(item => { %>
      <div class="card card-pad" style="display:flex;align-items:center;gap:16px;">
        <div class="thumb" style="width:70px;height:70px;border-radius:8px;overflow:hidden;flex-shrink:0;background:var(--green-100);display:flex;align-items:center;justify-content:center;">
          <% if (item.product.images && item.product.images.length) { %>
            <img src="<%= item.product.images[0] %>" style="width:100%;height:100%;object-fit:cover;" alt="">
          <% } else { %>
            <i class="fa-solid fa-box-open"></i>
          <% } %>
        </div>
        <div style="flex:1;">
          <strong><%= item.product.name %></strong>
          <div class="muted" style="font-size:0.85rem;">Rp <%= Number(item.product.price).toLocaleString('id-ID') %> / unit</div>
        </div>
        <form action="/cart/update" method="POST" style="display:flex;align-items:center;gap:6px;">
          <input type="hidden" name="productId" value="<%= item.productId %>">
          <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="<%= item.product.stock %>" style="width:64px;padding:6px;border:1px solid var(--line);border-radius:6px;">
          <button type="submit" class="btn btn-outline btn-sm">Update</button>
        </form>
        <div style="width:130px;text-align:right;font-weight:700;">
          Rp <%= (Number(item.product.price) * item.quantity).toLocaleString('id-ID') %>
        </div>
        <form action="/cart/remove/<%= item.productId %>" method="POST">
          <button type="submit" class="btn btn-danger btn-sm">&times;</button>
        </form>
      </div>
    <% }) %>
  </div>

  <div class="card card-pad" style="margin-top:20px;display:flex;justify-content:space-between;align-items:center;">
    <div style="font-size:1.2rem;font-weight:800;">Total: Rp <%= total.toLocaleString('id-ID') %></div>
    <a href="/checkout" class="btn btn-accent">Lanjut ke Checkout</a>
  </div>
<% } %>
