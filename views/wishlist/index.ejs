<h1>Wishlist Saya</h1>

<% if (items.length === 0) { %>
  <div class="empty-state">
    <div class="big">♥</div>
    <p>Belum ada produk di wishlist kamu.</p>
    <a href="/products" class="btn btn-primary">Jelajahi Produk</a>
  </div>
<% } else { %>
  <div class="grid grid-products" style="margin-top:20px;">
    <% items.forEach(item => { %>
      <div style="position:relative;">
        <%- include('../partials/product-card', { p: item.product }) %>
        <form action="/wishlist/toggle" method="POST" style="position:absolute;top:10px;right:10px;">
          <input type="hidden" name="productId" value="<%= item.productId %>">
          <button type="submit" class="btn btn-danger btn-sm">&times;</button>
        </form>
      </div>
    <% }) %>
  </div>
<% } %>
